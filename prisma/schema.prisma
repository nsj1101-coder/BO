generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id          Int      @id @default(autoincrement())
  loginId     String   @unique @map("login_id")
  password    String
  name        String
  role        String   @default("admin")
  isActive    Boolean  @default(true) @map("is_active")
  permissions String   @default("all") @map("permissions") @db.Text
  canManageAdmins Boolean @default(false) @map("can_manage_admins")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  logs AdminLog[]
  assignedLeads      CrmLead[]          @relation("LeadAssignee")
  assignedCustomers  CrmCustomer[]      @relation("CustomerAssignee")
  assignedConsults   CrmConsultation[]  @relation("ConsultAssignee")
  assignedFollowups  CrmFollowup[]      @relation("FollowupAssignee")
  assignedDeals      CrmDeal[]          @relation("DealAssignee")

  @@map("admins")
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int      @map("admin_id")
  action    String
  detail    String   @default("") @db.Text
  ip        String   @default("")
  userAgent String   @default("") @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model TemplateFolder {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("") @db.Text
  color       String   @default("#3182F6")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  templates Template[]

  @@map("template_folders")
}

model Template {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  folderId    Int?     @map("folder_id")
  category    String   @default("general")
  htmlContent String   @map("html_content") @db.Text
  cssContent  String   @default("") @map("css_content") @db.Text
  jsContent   String   @default("") @map("js_content") @db.Text
  thumbnail   String?
  isOriginal  Boolean  @default(true) @map("is_original")
  sourceId    Int?     @map("source_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  folder   TemplateFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  source   Template?  @relation("TemplateClones", fields: [sourceId], references: [id])
  clones   Template[] @relation("TemplateClones")
  sections PageSection[]
  banners  Banner[]
  versions TemplateVersion[]

  @@map("templates")
}

model TemplateVersion {
  id          Int      @id @default(autoincrement())
  templateId  Int      @map("template_id")
  version     Int
  htmlContent String   @map("html_content") @db.Text
  cssContent  String   @default("") @map("css_content") @db.Text
  jsContent   String   @default("") @map("js_content") @db.Text
  memo        String   @default("") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("template_versions")
}

model Page {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  pageType  String   @default("main") @map("page_type")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sections PageSection[]

  @@map("pages")
}

model PageSection {
  id          Int      @id @default(autoincrement())
  pageId      Int      @map("page_id")
  templateId  Int      @map("template_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  isFixed     Boolean  @default(false) @map("is_fixed")
  fixPosition String?  @map("fix_position")
  htmlContent String   @default("") @map("html_content") @db.Text
  cssContent  String   @default("") @map("css_content") @db.Text
  jsContent   String   @default("") @map("js_content") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  page     Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id])

  @@map("page_sections")
}

model Banner {
  id         Int      @id @default(autoincrement())
  templateId Int      @map("template_id")
  slotKey    String   @map("slot_key")
  imageUrl   String   @map("image_url")
  linkUrl    String?  @map("link_url")
  altText    String?  @map("alt_text")
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("banners")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Board {
  id            Int      @id @default(autoincrement())
  name          String
  boardId       String   @unique @map("board_id")
  boardType     String   @default("list") @map("board_type")
  isSecret      Boolean  @default(false) @map("is_secret")
  useComment    Boolean  @default(true) @map("use_comment")
  writeRole     String   @default("admin") @map("write_role")
  listRole      String   @default("all") @map("list_role")
  readRole      String   @default("all") @map("read_role")
  commentRole   String   @default("all") @map("comment_role")
  customCss     String   @default("") @map("custom_css") @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  posts Post[]

  @@map("boards")
}

model Post {
  id        Int      @id @default(autoincrement())
  boardId   Int      @map("board_id")
  title     String
  content   String   @db.Text
  author    String
  password  String?
  isSecret  Boolean  @default(false) @map("is_secret")
  viewCount Int      @default(0) @map("view_count")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  board    Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@map("posts")
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  content   String   @db.Text
  author    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Popup {
  id          Int       @id @default(autoincrement())
  title       String
  description String    @default("") @db.Text
  popupType   String    @default("image") @map("popup_type")
  imageUrl    String?   @map("image_url")
  htmlContent String    @default("") @map("html_content") @db.Text
  linkUrl     String?   @map("link_url")
  isActive    Boolean   @default(true) @map("is_active")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("popups")
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  category  String   @default("일반")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model MemberField {
  id          Int      @id @default(autoincrement())
  fieldKey    String   @unique @map("field_key")
  label       String
  fieldType   String   @default("text") @map("field_type")
  required    Boolean  @default(false)
  options     String   @default("") @map("options") @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("member_fields")
}

model Member {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  phone     String   @default("")
  isActive  Boolean  @default(true) @map("is_active")
  extraData String   @default("{}") @map("extra_data") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("members")
}

model FormConfig {
  id          Int      @id @default(autoincrement())
  formType    String   @unique @map("form_type")
  fields      String   @default("[]") @map("fields") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("form_configs")
}

model Consultation {
  id        Int      @id @default(autoincrement())
  data      String   @default("{}") @db.Text
  status    String   @default("pending")
  adminMemo String   @default("") @map("admin_memo") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("consultations")
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @default("")
  email     String   @default("")
  content   String   @db.Text
  status    String   @default("pending")
  adminMemo String   @default("") @map("admin_memo") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("inquiries")
}

model Reservation {
  id        Int      @id @default(autoincrement())
  data      String   @default("{}") @db.Text
  status    String   @default("pending")
  adminMemo String   @default("") @map("admin_memo") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reservations")
}

// ============================================
// CRM Models
// ============================================

model CrmLead {
  id              Int      @id @default(autoincrement())
  leadType        String   @default("inquiry") @map("lead_type")
  customerName    String   @map("customer_name")
  phone           String   @default("")
  email           String   @default("")
  companyName     String   @default("") @map("company_name")
  content         String   @default("") @db.Text
  landingPageUrl  String   @default("") @map("landing_page_url")
  referrerUrl     String   @default("") @map("referrer_url")
  utmSource       String   @default("") @map("utm_source")
  utmMedium       String   @default("") @map("utm_medium")
  utmCampaign     String   @default("") @map("utm_campaign")
  statusCode      String   @default("new") @map("status_code")
  priority        String   @default("normal")
  assigneeId      Int?     @map("assignee_id")
  customerId      Int?     @map("customer_id")
  nextActionDate  DateTime? @map("next_action_date")
  sourceFormId    Int?     @map("source_form_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer        CrmCustomer? @relation(fields: [customerId], references: [id])
  assignee        Admin?       @relation("LeadAssignee", fields: [assigneeId], references: [id])
  consultations   CrmConsultation[]
  followups       CrmFollowup[]
  statusHistory   CrmLeadStatusHistory[]
  deals           CrmDeal[]

  @@map("crm_leads")
}

model CrmCustomer {
  id              Int      @id @default(autoincrement())
  customerType    String   @default("individual") @map("customer_type")
  name            String
  companyName     String   @default("") @map("company_name")
  phone           String   @default("")
  email           String   @default("")
  birthOrBizNo    String   @default("") @map("birth_or_biz_no")
  grade           String   @default("일반")
  tags            String   @default("") @db.Text
  consentSms      Boolean  @default(false) @map("consent_sms")
  consentEmail    Boolean  @default(false) @map("consent_email")
  mainAssigneeId  Int?     @map("main_assignee_id")
  currentStatus   String   @default("active") @map("current_status")
  expectedRevenue Int      @default(0) @map("expected_revenue")
  isBlacklisted   Boolean  @default(false) @map("is_blacklisted")
  memo            String   @default("") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  mainAssignee    Admin?   @relation("CustomerAssignee", fields: [mainAssigneeId], references: [id])
  leads           CrmLead[]
  consultations   CrmConsultation[]
  followups       CrmFollowup[]
  deals           CrmDeal[]

  @@map("crm_customers")
}

model CrmConsultation {
  id              Int      @id @default(autoincrement())
  leadId          Int?     @map("lead_id")
  customerId      Int?     @map("customer_id")
  consultType     String   @default("phone") @map("consult_type")
  assigneeId      Int?     @map("assignee_id")
  content         String   @default("") @db.Text
  summary         String   @default("") @db.Text
  needs           String   @default("")
  budget          String   @default("")
  desiredDate     String   @default("") @map("desired_date")
  requestedService String  @default("") @map("requested_service")
  result          String   @default("pending")
  failReason      String   @default("") @map("fail_reason")
  nextAction      String   @default("") @map("next_action")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lead            CrmLead?    @relation(fields: [leadId], references: [id])
  customer        CrmCustomer? @relation(fields: [customerId], references: [id])
  assignee        Admin?       @relation("ConsultAssignee", fields: [assigneeId], references: [id])

  @@map("crm_consultations")
}

model CrmFollowup {
  id              Int      @id @default(autoincrement())
  title           String
  taskType        String   @default("call") @map("task_type")
  leadId          Int?     @map("lead_id")
  customerId      Int?     @map("customer_id")
  assigneeId      Int?     @map("assignee_id")
  status          String   @default("pending")
  priority        String   @default("normal")
  dueDate         DateTime? @map("due_date")
  completedAt     DateTime? @map("completed_at")
  memo            String   @default("") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lead            CrmLead?    @relation(fields: [leadId], references: [id])
  customer        CrmCustomer? @relation(fields: [customerId], references: [id])
  assignee        Admin?       @relation("FollowupAssignee", fields: [assigneeId], references: [id])

  @@map("crm_followups")
}

model CrmLeadStatusHistory {
  id              Int      @id @default(autoincrement())
  leadId          Int      @map("lead_id")
  fromStatus      String   @map("from_status")
  toStatus        String   @map("to_status")
  changedBy       Int?     @map("changed_by")
  memo            String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")

  lead            CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("crm_lead_status_history")
}

model CrmStatusCode {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  label           String
  color           String   @default("#666")
  sortOrder       Int      @default(0) @map("sort_order")
  isDefault       Boolean  @default(false) @map("is_default")
  isFinal         Boolean  @default(false) @map("is_final")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("crm_status_codes")
}

model CrmDeal {
  id              Int      @id @default(autoincrement())
  title           String
  customerId      Int?     @map("customer_id")
  leadId          Int?     @map("lead_id")
  assigneeId      Int?     @map("assignee_id")
  stage           String   @default("new")
  amount          Int      @default(0)
  probability     Int      @default(0)
  expectedCloseDate DateTime? @map("expected_close_date")
  wonLost         String?  @map("won_lost")
  lostReason      String   @default("") @map("lost_reason")
  memo            String   @default("") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer        CrmCustomer? @relation(fields: [customerId], references: [id])
  lead            CrmLead?     @relation(fields: [leadId], references: [id])
  assignee        Admin?       @relation("DealAssignee", fields: [assigneeId], references: [id])
  quotes          CrmQuote[]
  contracts       CrmContract[]

  @@map("crm_deals")
}

model CrmQuote {
  id              Int      @id @default(autoincrement())
  dealId          Int      @map("deal_id")
  quoteNumber     String   @unique @map("quote_number")
  title           String
  items           String   @default("[]") @db.Text
  totalAmount     Int      @default(0) @map("total_amount")
  validUntil      DateTime? @map("valid_until")
  status          String   @default("draft")
  memo            String   @default("") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  deal            CrmDeal  @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("crm_quotes")
}

model CrmContract {
  id              Int      @id @default(autoincrement())
  dealId          Int      @map("deal_id")
  contractNumber  String   @unique @map("contract_number")
  title           String
  amount          Int      @default(0)
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  status          String   @default("draft")
  memo            String   @default("") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  deal            CrmDeal  @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("crm_contracts")
}

model CrmCampaign {
  id              Int      @id @default(autoincrement())
  name            String
  campaignType    String   @default("email") @map("campaign_type")
  status          String   @default("draft")
  targetSegment   String   @default("") @map("target_segment") @db.Text
  content         String   @default("") @db.Text
  sentCount       Int      @default(0) @map("sent_count")
  openCount       Int      @default(0) @map("open_count")
  clickCount      Int      @default(0) @map("click_count")
  convertCount    Int      @default(0) @map("convert_count")
  scheduledAt     DateTime? @map("scheduled_at")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("crm_campaigns")
}

// ============================================
// Homepage Analytics / Tracking
// ============================================

model TrackSession {
  id            Int      @id @default(autoincrement())
  sessionId     String   @unique @map("session_id")
  visitorId     String   @map("visitor_id")
  memberId      Int?     @map("member_id")
  ip            String   @default("")
  userAgent     String   @default("") @map("user_agent") @db.Text
  device        String   @default("")
  browser       String   @default("")
  os            String   @default("")
  country       String   @default("")
  city          String   @default("")
  referrer      String   @default("")
  utmSource     String   @default("") @map("utm_source")
  utmMedium     String   @default("") @map("utm_medium")
  utmCampaign   String   @default("") @map("utm_campaign")
  landingPage   String   @default("") @map("landing_page")
  exitPage      String   @default("") @map("exit_page")
  pageCount     Int      @default(0) @map("page_count")
  duration      Int      @default(0)
  isNewVisitor  Boolean  @default(true) @map("is_new_visitor")
  startedAt     DateTime @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")

  pageViews     TrackPageView[]
  events        TrackEvent[]

  @@map("track_sessions")
}

model TrackPageView {
  id            Int      @id @default(autoincrement())
  sessionId     String   @map("session_id")
  visitorId     String   @map("visitor_id")
  memberId      Int?     @map("member_id")
  path          String
  title         String   @default("")
  referrer      String   @default("")
  duration      Int      @default(0)
  scrollDepth   Int      @default(0) @map("scroll_depth")
  createdAt     DateTime @default(now()) @map("created_at")

  session       TrackSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@map("track_page_views")
}

model TrackEvent {
  id            Int      @id @default(autoincrement())
  sessionId     String   @map("session_id")
  visitorId     String   @map("visitor_id")
  memberId      Int?     @map("member_id")
  eventType     String   @map("event_type")
  eventName     String   @map("event_name")
  path          String   @default("")
  target        String   @default("")
  value         String   @default("")
  metadata      String   @default("{}") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  session       TrackSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@map("track_events")
}

model TrackHeatmapClick {
  id            Int      @id @default(autoincrement())
  path          String
  x             Int
  y             Int
  viewportW     Int      @map("viewport_w")
  viewportH     Int      @map("viewport_h")
  target        String   @default("")
  sessionId     String   @map("session_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("track_heatmap_clicks")
}
